# luxury-textile-app — environment variables (.env namunasi)

# Postgres ulanish satri — Neon tavsiya etiladi (cloud, VPS resursini yemaydi)
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/DB?sslmode=require

# Sessiya shifrlash kaliti — `openssl rand -hex 32` bilan yarating
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Server porti va muhit
PORT=5000
NODE_ENV=production

# Birinchi admin akkaunt paroli (username server/dbStorage.ts ichida belgilangan)
ADMIN_PASSWORD=change-me

# OpenAI (AI funksiyalari). Bo'lmasa placeholder qo'ying — server baribir ishga tushadi:
OPENAI_API_KEY=sk-placeholder-not-configured

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOY ESLATMASI:
#  1) npm ci && npm run build
#  2) Yangi bazada `session` jadvalini QO'LDA yarating
#     (connect-pg-simple table.sql bundle'ga kirmaydi):
#        CREATE TABLE IF NOT EXISTS "session" (
#          "sid" varchar NOT NULL,
#          "sess" json NOT NULL,
#          "expire" timestamp(6) NOT NULL,
#          CONSTRAINT "session_pkey" PRIMARY KEY ("sid")
#        );
#        CREATE INDEX IF NOT EXISTS "IDX_session_expire" ON "session" ("expire");
#  3) npm run db:push   (Drizzle schema)
#  4) pm2 start dist/index.cjs --name luxury --node-args="--env-file=/path/.env"
# ─────────────────────────────────────────────────────────────────────────────
