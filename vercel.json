{
  "version": 2,
  "functions": {
    "server/index.ts": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.ts" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
